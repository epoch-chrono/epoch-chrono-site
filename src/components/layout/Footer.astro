---
// Footer.astro
const year = new Date().getFullYear();
---

<footer class="border-t border-[#1e2d4a] mt-16">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-6 flex items-center justify-between">
    <span class="font-mono text-xs text-[#4a607f]">
      &copy; {year} Vitor Jr
    </span>
    <div class="flex items-center gap-4">
      <a
        href="https://github.com/epoch-chrono"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-xs text-[#4a607f] hover:text-[#8fa3c8] transition-colors"
      >
        github
      </a>
      <a
        href="/rss.xml"
        class="font-mono text-xs text-[#4a607f] hover:text-[#8fa3c8] transition-colors"
      >
        rss
      </a>
    </div>
  </div>
</footer>
