---
// PostCard.astro
import { formatDate, readingTime } from '../../utils/date';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  categories?: string[];
  body?: string;
}

const { title, description, pubDate, slug, tags = [], categories = [], body = '' } = Astro.props;
const mins = readingTime(body);
---

<a
  href={`/blog/${slug}`}
  class="block group border border-[#1e2d4a] bg-[#0f1629] rounded p-5
         hover:border-[#00c8e0] hover:bg-[#162040] transition-colors"
>
  {categories.length > 0 && (
    <div class="flex gap-2 mb-2">
      {categories.map((cat) => (
        <span class="font-mono text-xs text-[#6b4fc8]">{cat}</span>
      ))}
    </div>
  )}

  <h2 class="text-base font-semibold text-[#e8edf7] group-hover:text-[#00c8e0]
             transition-colors leading-snug mb-1">
    {title}
  </h2>

  <p class="text-sm text-[#8fa3c8] line-clamp-2 mb-3">{description}</p>

  <div class="flex items-center justify-between">
    <span class="font-mono text-xs text-[#4a607f]">
      {formatDate(pubDate)} · {mins} min
    </span>
    {tags.length > 0 && (
      <div class="flex gap-1">
        {tags.slice(0, 3).map((tag) => (
          <span class="font-mono text-xs text-[#00c8e0] border border-[#1e2d4a]
                       bg-[#162040] rounded px-2 py-0.5">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
