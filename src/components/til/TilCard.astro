---
// TilCard.astro
import { formatDate } from '../../utils/date';

interface Props {
  title: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
}

const { title, pubDate, slug, tags = [] } = Astro.props;
---

<a
  href={`/til/${slug}`}
  class="flex items-start justify-between gap-4 group py-3 border-b border-[#1e2d4a]
         hover:border-[#00c8e0] transition-colors"
>
  <span class="text-sm text-[#e8edf7] group-hover:text-[#00c8e0] transition-colors leading-snug">
    {title}
  </span>

  <div class="flex items-center gap-3 shrink-0">
    {tags.slice(0, 2).map((tag) => (
      <span class="font-mono text-xs text-[#4a607f]">{tag}</span>
    ))}
    <span class="font-mono text-xs text-[#4a607f] whitespace-nowrap">
      {formatDate(pubDate)}
    </span>
  </div>
</a>
