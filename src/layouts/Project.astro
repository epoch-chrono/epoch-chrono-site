---
// Project.astro — layout para projetos individuais
import BaseLayout from '../components/layout/BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  status: 'active' | 'archived' | 'wip';
  repo?: string;
  demo?: string;
  tags?: string[];
}

const { title, description, status, repo, demo, tags = [] } = Astro.props;

const statusConfig = {
  active:   { label: 'active',   classes: 'text-[#00e896] border-[#00e896]/30 bg-[#00e896]/10' },
  wip:      { label: 'wip',      classes: 'text-[#f0a830] border-[#f0a830]/30 bg-[#f0a830]/10' },
  archived: { label: 'archived', classes: 'text-[#4a607f] border-[#4a607f]/30 bg-[#4a607f]/10' },
};
const st = statusConfig[status];
---

<BaseLayout {title} {description}>
  <article>
    <header class="mb-10 space-y-4">
      <div class="flex items-center gap-3">
        <span class={`font-mono text-xs border rounded px-2 py-0.5 ${st.classes}`}>
          {st.label}
        </span>
      </div>

      <h1 class="text-3xl font-semibold tracking-tight text-[#e8edf7]">{title}</h1>
      <p class="text-base text-[#8fa3c8]">{description}</p>

      <div class="flex gap-4">
        {repo && (
          <a href={repo} target="_blank" rel="noopener noreferrer"
             class="font-mono text-sm text-[#00c8e0] hover:underline">
            github →
          </a>
        )}
        {demo && (
          <a href={demo} target="_blank" rel="noopener noreferrer"
             class="font-mono text-sm text-[#00c8e0] hover:underline">
            demo →
          </a>
        )}
      </div>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="font-mono text-xs text-[#8fa3c8] border border-[#1e2d4a]
                         bg-[#0f1629] rounded px-2 py-0.5">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-invert max-w-none
                prose-a:text-[#00c8e0] prose-a:no-underline hover:prose-a:underline
                prose-code:text-[#00c8e0] prose-code:bg-[#0f1629] prose-code:px-1 prose-code:rounded
                prose-pre:bg-[#0f1629] prose-pre:border prose-pre:border-[#1e2d4a]">
      <slot />
    </div>
  </article>
</BaseLayout>
