---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { getPublishedPosts } from '../../utils/content';

const posts = await getPublishedPosts();
---

<BaseLayout
  title="blog — epoch-chrono"
  description="Posts técnicos sobre SRE, plataformas e engenharia."
>
  <section class="space-y-8">
    <header class="space-y-1">
      <h1 class="text-2xl font-semibold tracking-tight text-[#e8edf7]">blog</h1>
      <p class="font-mono text-sm text-[#4a607f]">{posts.length} posts</p>
    </header>

    {posts.length === 0 ? (
      <p class="font-mono text-sm text-[#4a607f]">nenhum post ainda.</p>
    ) : (
      <div class="space-y-3">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
            categories={post.data.categories}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
