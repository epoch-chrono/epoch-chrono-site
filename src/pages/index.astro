---
import BaseLayout from '../components/layout/BaseLayout.astro';

const socials = [
  { href: 'https://github.com/vjunior1981', label: 'github' },
  { href: 'https://x.com/vjunior1981', label: 'x / twitter' },
  { href: 'https://bsky.app/profile/vjunior1981.bsky.social', label: 'bluesky' },
  { href: 'https://www.linkedin.com/in/vitorjr/', label: 'linkedin' },
];

const navLinks = [
  { href: '/blog', label: 'blog' },
  { href: '/til', label: 'til' },
  { href: '/projects', label: 'projects' },
  { href: '/uses', label: 'uses' },
  { href: '/now', label: 'now' },
];
---

<BaseLayout
  title="epoch-chrono — Vitor Jr"
  description="SRE & platform engineer. Blog técnico, TIL e projetos open source."
>
  <section class="space-y-10">

    <!-- Foto + nome -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
      <img
        src="/assets/vitor-benji.jpg"
        alt="Vitor Jr e Benji"
        class="w-28 h-28 rounded-full object-cover object-top grayscale opacity-90"
        loading="eager"
      />
      <div class="space-y-1">
        <h1 class="text-2xl font-semibold tracking-tight text-[#e8edf7]">
          Vitor Jr
        </h1>
        <p class="text-sm font-mono text-[#00c8e0]">
          SRE · platform engineer · sobrevivente
        </p>
      </div>
    </div>

    <!-- Bio zoeira -->
    <div class="space-y-4 text-[#8fa3c8] leading-relaxed">
      <p>
        Desde 1994 aprendendo que computador quebra.<br />
        Desde 2005 sendo pago pra fingir que sei consertar.
      </p>
      <p>
        20 anos de carreira. A maior parte em plantão.<br />
        O resto em reunião explicando por que o plantão aconteceu.
      </p>
      <p>
        Trabalho com infraestrutura, confiabilidade e plataformas internas —
        basicamente passo raiva de segunda a domingo com Kubernetes, Git,
        shell scripts, banco de dados, cloud, observabilidade e você,
        sim você, que abriu um PR sem descrição às 23h de sexta.
      </p>
      <p>
        Tenho um filho (Benji) que entende mais de brinquedo do que eu de YAML
        e uma esposa (Carol) que adora quando trabalho até mais tarde,
        assim eu não torro a paciência dela.
        Isso diz muito sobre YAML, sobre minha esposa e sobre eu.
      </p>
    </div>

    <!-- Redes sociais -->
    <nav aria-label="Redes sociais">
      <ul class="flex flex-wrap gap-x-5 gap-y-2">
        {socials.map(({ href, label }) => (
          <li>
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="font-mono text-sm text-[#8fa3c8] hover:text-[#00c8e0] transition-colors"
            >
              → {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Disclaimer -->
    <p class="text-xs text-[#4a5a7a] leading-relaxed border-t border-[#1e2a3a] pt-6">
      As opiniões, reclamações, desabafos e textos publicados aqui são
      exclusivamente meus e não representam, nunca representaram e
      provavelmente nunca representarão a visão do meu empregador,
      dos meus clientes, dos meus colegas ou de qualquer outra entidade
      com bom senso suficiente pra se distanciar do que escrevo.
    </p>

    <!-- Navegação interna -->
    <nav aria-label="Seções do site">
      <ul class="flex flex-wrap gap-x-5 gap-y-2">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="font-mono text-sm text-[#8fa3c8] hover:text-[#00c8e0] transition-colors"
            >
              /{label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

  </section>
</BaseLayout>
