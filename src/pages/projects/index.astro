---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getProjects } from '../../utils/content';

const projects = await getProjects();

const statusConfig = {
  active:   { label: 'active',   classes: 'text-[#00e896] border-[#00e896]/30 bg-[#00e896]/10' },
  wip:      { label: 'wip',      classes: 'text-[#f0a830] border-[#f0a830]/30 bg-[#f0a830]/10' },
  archived: { label: 'archived', classes: 'text-[#4a607f] border-[#4a607f]/30 bg-[#4a607f]/10' },
};
---

<BaseLayout
  title="projects — epoch-chrono"
  description="Projetos open source e side projects."
>
  <section class="space-y-8">
    <header class="space-y-1">
      <h1 class="text-2xl font-semibold tracking-tight text-[#e8edf7]">projects</h1>
      <p class="font-mono text-sm text-[#4a607f]">{projects.length} projetos</p>
    </header>

    {projects.length === 0 ? (
      <p class="font-mono text-sm text-[#4a607f]">nenhum projeto ainda.</p>
    ) : (
      <div class="space-y-3">
        {projects.map((project) => {
          const st = statusConfig[project.data.status];
          return (
            <a
              href={`/projects/${project.id}`}
              class="block group border border-[#1e2d4a] bg-[#0f1629] rounded p-5
                     hover:border-[#00c8e0] hover:bg-[#162040] transition-colors"
            >
              <div class="flex items-start justify-between gap-4 mb-2">
                <h2 class="text-base font-semibold text-[#e8edf7]
                           group-hover:text-[#00c8e0] transition-colors">
                  {project.data.title}
                </h2>
                <span class={`font-mono text-xs border rounded px-2 py-0.5 shrink-0 ${st.classes}`}>
                  {st.label}
                </span>
              </div>
              <p class="text-sm text-[#8fa3c8] mb-3">{project.data.description}</p>
              {project.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1">
                  {project.data.tags.slice(0, 4).map((tag) => (
                    <span class="font-mono text-xs text-[#4a607f]">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          );
        })}
      </div>
    )}
  </section>
</BaseLayout>
