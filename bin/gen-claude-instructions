#!/usr/bin/env python3
"""
gen-claude-instructions v1.1.0

Gera .mind/PROJECT_INSTRUCTIONS.claude.md a partir de:
  - .mind/PROJECT_INSTRUCTIONS.md (corpo público, até <!-- BEGIN_VARIABLES -->)
  - .envrc (credenciais reais, injetadas no bloco de variáveis)

Também regera .envrc.example mascarando secrets longos.

Uso:
  gen-claude-instructions            # gera e imprime no stdout
  gen-claude-instructions --dry      # só imprime, não salva arquivos
  gen-claude-instructions --dry-run  # idem (alias)
"""

import re
import sys
from pathlib import Path

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
ROOT = Path("/Users/maxter/Git/OpenCodeSpace/personal/epoch-chrono-site")
ENVRC       = ROOT / ".envrc"
SRC_MD      = ROOT / ".mind" / "PROJECT_INSTRUCTIONS.md"
OUT_CLAUDE  = ROOT / ".mind" / "PROJECT_INSTRUCTIONS.claude.md"
OUT_EXAMPLE = ROOT / ".envrc.example"

BEGIN_MARKER = "<!-- BEGIN_VARIABLES -->"

DRY_RUN = any(a in ("--dry", "--dry-run") for a in sys.argv[1:])

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def mask_value(val: str) -> str:
    """Keep URLs and short values intact; mask long secrets."""
    if val.startswith("http"):
        return val
    if len(val) <= 30:
        return val
    return val[:5] + "..."


def parse_envrc(path: Path) -> list[tuple[str, str | None, str | None]]:
    """
    Parse .envrc lines.
    Returns list of (original_line, varname_or_None, value_or_None).
    Only matches lines of the form: export VAR_NAME='value'
    """
    result = []
    pattern = re.compile(r'^export\s+([A-Z_][A-Z0-9_]*)=\'(.*)\'$')
    with open(path) as f:
        for line in f:
            line = line.rstrip("\n")
            m = pattern.match(line)
            if m:
                result.append((line, m.group(1), m.group(2)))
            else:
                result.append((line, None, None))
    return result

# ---------------------------------------------------------------------------
# Step 1 — .envrc.example
# ---------------------------------------------------------------------------

def build_example(parsed: list) -> str:
    lines = []
    for original, varname, value in parsed:
        if varname is not None:
            masked = mask_value(value)
            lines.append(f"export {varname}='{masked}'")
        else:
            lines.append(original)
    return "\n".join(lines) + "\n"

# ---------------------------------------------------------------------------
# Step 2+3 — PROJECT_INSTRUCTIONS.claude.md
# ---------------------------------------------------------------------------

def build_claude_md(parsed: list, src_md: Path) -> str:
    md_content = src_md.read_text()

    marker_pos = md_content.find(BEGIN_MARKER)
    if marker_pos == -1:
        print(f"ERROR: '{BEGIN_MARKER}' não encontrado em {src_md}", file=sys.stderr)
        sys.exit(1)

    # Tudo até o marker (inclusive linha antes)
    base = md_content[:marker_pos].rstrip("\n") + "\n\n"

    # Bloco de variáveis gerado a partir do .envrc real
    var_block_lines = [
        "<!-- BEGIN_VARIABLES -->",
        "## Variables",
        "",
        "> Valores reais definidos em `.envrc` (não commitado).",
        "> Ver `.envrc.example` para lista completa de variáveis necessárias.",
        "",
        "```bash",
    ]
    for original, varname, value in parsed:
        if varname is not None:
            var_block_lines.append(f"export {varname}='{value}'")
        else:
            # Preserva comentários e linhas em branco do .envrc
            stripped = original.strip()
            if stripped == "" or stripped.startswith("#"):
                var_block_lines.append(original)
            # Ignora source_up e PATH — não relevantes para o claude.md
    var_block_lines.append("```")
    var_block_lines.append("<!-- END_VARIABLES -->")

    return base + "\n".join(var_block_lines) + "\n"

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parsed = parse_envrc(ENVRC)

    # .envrc.example
    example_content = build_example(parsed)
    if not DRY_RUN:
        OUT_EXAMPLE.write_text(example_content)
        print(f"✓ {OUT_EXAMPLE}", file=sys.stderr)
    else:
        print(f"[dry] .envrc.example skipped", file=sys.stderr)

    # PROJECT_INSTRUCTIONS.claude.md
    claude_content = build_claude_md(parsed, SRC_MD)
    if not DRY_RUN:
        OUT_CLAUDE.write_text(claude_content)
        print(f"✓ {OUT_CLAUDE}", file=sys.stderr)
    else:
        print(f"[dry] PROJECT_INSTRUCTIONS.claude.md skipped", file=sys.stderr)

    # Stdout — para copy/paste
    print(claude_content)


if __name__ == "__main__":
    main()
